{
  "name": "satisfactory-blueprint-organizer",
  "version": "1.1.5",
  "private": true,
  "type": "module",
  "main": "out/main/electron.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist": "npm run build && electron-builder --win --dir",
    "dist:nsis": "npm run build && electron-builder --win",
    "test": "vitest run",
    "dump-save": "tsx scripts/dump-save.ts",
    "scan-blueprint-structure": "tsx scripts/scan-blueprint-structure.ts",
    "diff-save-blueprint-category": "tsx scripts/diff-save-blueprint-category.ts",
    "compress-icons": "tsx scripts/compress-blueprint-icons.ts"
  },
  "dependencies": {
    "@etothepii/satisfactory-file-parser": "^4.1.1",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.3",
    "fflate": "^0.8.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.6"
  },
  "build": {
    "afterPack": "scripts/afterPack.cjs",
    "releaseInfo": {
      "releaseNotesFile": "RELEASE_NOTES.md"
    },
    "appId": "dev.local.satisfactory-blueprint-organizer",
    "productName": "Satisfactory Blueprint Organizer",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Satisfactory-Blueprint-Organizer-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "maintainer": "Eldon27232",
      "artifactName": "Satisfactory-Blueprint-Organizer-${version}.${ext}"
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Eldon27232",
        "repo": "satisfactory-blueprint-organizer"
      }
    ]
  }
}
